export default async function handler(req, res) {
  // CORS 헤더 설정
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  
  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  const { symbol, name, price, change, sector, type, keywords, desc } = req.body;
  const API_KEY = process.env.ANTHROPIC_API_KEY;

  try {
    let prompt = "";

    // 1. 프론트엔드의 각 기능(type)별로 프롬프트 분기 처리
    if (type === 'reddit') {
      prompt = `현재 글로벌 주식 커뮤니티(Reddit의 r/stocks, r/wallstreetbets)에서 가장 뜨겁게 언급되고 있는 인기 주식 3가지를 선정하고, 왜 핫한지 언급량 트렌드를 요약 요약해줘. 한국어로 친근하고 가독성 좋게 작성해줘.`;
    } 
    else if (type === 'etf') {
      prompt = `사용자가 선택한 키워드 [${keywords ? keywords.join(', ') : ''}]를 기반으로 한 혁신적인 '미니 ETF' 포트폴리오를 구성해줘. 포함될 가상의 혹은 실제 종목 3~4개와 각각의 자산 배분 비중(%), 그리고 이 ETF의 투자 컨셉 핵심 요약을 한국어로 깔끔하게 작성해줘.`;
    } 
    else if (type === 'etf_hint') {
      prompt = `${name}(${symbol})이 "${keyword}" 키워드와 연관된 이유를 한 문장(30자 이내)으로만 답해주세요.`;
    } 
    else {
      // 일반 종목 상세 분석 (기본값)
      prompt = `주식 애널리스트로서 ${name}(${symbol})에 대한 실시간 커뮤니티 언급량과 최신 트렌드를 분석해줘. 기업 개요: ${desc || '정보 없음'}. 종합 투자 매력도와 리스크, 향후 전망을 포함해서 사용자가 읽기 쉽게 한눈에 들어오는 가독성 좋은 한국어로 작성해줘.`;
    }

    // 2. Anthropic API 호출
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json', 
        'x-api-key': API_KEY, 
        'anthropic-version': '2023-06-01' 
      },
      body: JSON.stringify({ 
        // 🔥 [수정]: 올바른 최신 클로드 모델명으로 교체했습니다.
        model: 'claude-3-5-sonnet-20241022', 
        max_tokens: 1024, 
        messages: [{ role: 'user', content: prompt }] 
      })
    });

    if (!response.ok) {
      const errorData = await response.json();
      throw new Error(`Anthropic API Error: ${JSON.stringify(errorData)}`);
    }

    const data = await response.json();
    const text = data.content[0].text;

    // 3. 프론트엔드가 기대하는 규격에 맞춰 안전하게 JSON 리턴
    if (type === 'etf_hint') {
      return res.status(200).json({ hint: text.trim() });
    }

    // 프론트엔드가 받아 쓰는 resData.data 규격에 맞춤
    return res.status(200).json({ data: text });

  } catch (e) {
    console.error("백엔드 에러 상세:", e.message);
    return res.status(500).json({ error: e.message });
  }
}
